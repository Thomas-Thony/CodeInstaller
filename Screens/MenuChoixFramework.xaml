<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodeInstaller.Screens.MenuChoixFramework"
             xmlns:viewmodels="clr-namespace:CodeInstaller.Classes"
             Title="Choix du framework">
    <CollectionView x:Name="lesFrameworks" ItemsLayout="VerticalGrid,3" SelectionMode="Single">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewmodels:Framework">
                <Border Stroke="#efefef">
                    <FlexLayout Direction="Row" Wrap="Wrap">
                    <Label 
                        Grid.Row="1"
                        Text="{Binding Nom}"
                        FontAttributes="Bold"
                     />

                     <Image 
                         Source="{Binding Logo}"
                         Aspect="AspectFill"
                         HeightRequest="60"
                         WidthRequest="60"
                        />

                       <Button
                          Grid.Column="1"
                          Grid.Row="4"
                          Text="Créer"
                          Clicked="CreateProjet"
                          CommandParameter="{Binding .}"
                          MaximumWidthRequest="70"
                          MaximumHeightRequest="70"
                        />
                    </FlexLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>