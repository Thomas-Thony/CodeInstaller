<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CodeInstaller.Classes"
             x:DataType="viewmodels:CodeInit"
             x:Class="CodeInstaller.Screens.MenuCreationProjet"
             Title="Créer un projet">
    <VerticalStackLayout>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="AUTO"/>
            </Grid.RowDefinitions>

            <CollectionView x:Name="CollectionLangages" EmptyView="Aucun langage disponible" WidthRequest="600" SelectionMode="Single">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="20"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:Langage">
                        <Border MinimumHeightRequest="100" Stroke="#efefef">
                            <Grid Padding="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label Text="{Binding ALangage}" Grid.Column="1" Grid.Row="1"/>
                                <Image
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Source="{Binding Image}"
                                    Aspect="AspectFill"
                                    HeightRequest="60"
                                    WidthRequest="60" 
                                />
                                <Button
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CreateProjetCommand}"
                                    CommandParameter="{Binding .}"
                                    Grid.Column="3"
                                    Grid.Row="3"
                                    Clicked="OnCreatePorjectByLangage"
                                    Text="{Binding ALangage, StringFormat='Créer un projet avec {0}'}"
                                    HeightRequest="40" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </VerticalStackLayout>
</ContentPage>